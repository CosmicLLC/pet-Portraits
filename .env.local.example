GEMINI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DIGITAL_PRICE_ID=
STRIPE_WALLPAPER_PRICE_ID=
STRIPE_DISPLAY_PRICE_ID=
STRIPE_MOUNTED_PRICE_ID=
STRIPE_CANVAS_PRICE_ID=
STRIPE_BUNDLE_PRICE_ID=
# ─── Expansion catalog ────────────────────────────────────────────────
# Each of the below unlocks one product tile in ProductSelector when
# set. Create a Product in Stripe, grab its Price ID, paste here.
STRIPE_CANVAS_16X20_PRICE_ID=
STRIPE_MULTIPET_PRICE_ID=
STRIPE_GALLERY_SET_PRICE_ID=
STRIPE_ACRYLIC_PRICE_ID=
STRIPE_METAL_PRICE_ID=
STRIPE_CARDS_PRICE_ID=
STRIPE_PHONE_CASE_PRICE_ID=
STRIPE_PRISM_PRICE_ID=
STRIPE_MUG_PRICE_ID=
STRIPE_PILLOW_PRICE_ID=
RESEND_API_KEY=
BLOB_READ_WRITE_TOKEN=
NEXT_PUBLIC_BASE_URL=
# Stripe customer portal login link — grab from dashboard.stripe.com/settings/billing/portal
STRIPE_BILLING_PORTAL_URL=
FROM_EMAIL=Paw Masterpiece <orders@yourdomain.com>

# Prodigi print-on-demand (display/mounted/canvas/bundle fulfillment)
# Leave blank until you have an account — the webhook will skip Prodigi
# and log a warning; you can manually submit orders from the admin page.
PRODIGI_ENV=sandbox
PRODIGI_API_KEY=
PRODIGI_DISPLAY_SKU=GLOBAL-MINI-11X14
PRODIGI_MOUNTED_SKU=GLOBAL-MOUNTED-MINI-11X14
PRODIGI_CANVAS_SKU=ECO-FRA-CAN-8X12
# Expansion — look up SKUs in the Prodigi catalog. Leave blank to hide.
PRODIGI_CANVAS_16X20_SKU=
PRODIGI_GALLERY_SET_SKU=
PRODIGI_ACRYLIC_SKU=
PRODIGI_METAL_SKU=
PRODIGI_CARDS_SKU=
PRODIGI_PHONE_CASE_SKU=
PRODIGI_PRISM_SKU=
PRODIGI_MUG_SKU=
PRODIGI_PILLOW_SKU=
PRODIGI_WEBHOOK_SECRET=

# Replicate (AI upscaler — runs only on paid orders before printing)
# Leave blank to ship the original 1024×1024 Gemini output (will look soft
# at 11×14+ print sizes). Get a token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# ─── Analytics / Ad Pixels ─────────────────────────────────────────────────
# All optional — missing IDs cause the tracking scripts to render nothing, so
# local dev stays clean. Paste real IDs when you're ready to start tracking.
#
# GA4: Admin → Data Streams → Web → Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
# Meta Pixel: Events Manager → Data Sources → your pixel (15-digit numeric ID)
NEXT_PUBLIC_META_PIXEL_ID=
# TikTok Pixel: TikTok Ads Manager → Assets → Events → Web Events (C + 19 chars)
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
# Set to "true" to console.log every analytics event (useful for local testing)
NEXT_PUBLIC_ANALYTICS_DEBUG=
# Pinterest domain verify token — paste from pinterest.com/settings/claim.
# Required to enable rich pins (live pricing, aggregate rating) when users
# save our pages. Leave blank until you've claimed the domain.
PINTEREST_DOMAIN_VERIFY=
# Google Search Console verification — search.google.com/search-console →
# Add property → pick "HTML tag" method → copy the content="..." value
# (the token string only, not the whole <meta> tag). Deploy, click Verify.
GOOGLE_SITE_VERIFICATION=
# Bing Webmaster Tools verification — bing.com/webmasters → Add site →
# HTML meta tag method → copy the content="..." value. Also used by
# DuckDuckGo and ChatGPT's search integration.
BING_SITE_VERIFICATION=
